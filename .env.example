# Server only — NEVER prefix with NEXT_PUBLIC_
CLAUDE_API_KEY=sk-ant-api03-...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
AUTH_SECRET=replace-with-random-32-char-minimum-secret
# Resend (waitlist confirmation + notifications). Never use NEXT_PUBLIC_ for this.
RESEND_API_KEY=re_your_key_here

# Safe for frontend
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Shown on Terms & Privacy, footer mailto. Optional; defaults to info@immifina.org
NEXT_PUBLIC_CONTACT_EMAIL=info@immifina.org
# Site URL for metadata / absolute links (production).
NEXT_PUBLIC_APP_URL=https://immifina.org

# CORS allowlist for /api (comma-separated). Defaults include https://immifina.org and local dev.
# ALLOWED_ORIGINS=https://immifina.org,http://localhost:3000

# Paste values without wrapping quotes in the Vercel UI. If login fails with
# AUTH_SECRET "set", re-paste the value and trim any accidental newline at the end.

# Local development: copy this file to .env.local and set:
#   NEXT_PUBLIC_APP_URL=http://localhost:3000
# (Keep production values in Vercel → Environment Variables for Preview/Production.)

# Optional — load simulation (scripts/vibe-flow-simulation.mjs), not used by the app:
# SIM_BASE_URL=http://localhost:3000
# SIM_EMAIL=
# SIM_PASSWORD=
# SIM_USERS=15
# SIM_LOOPS=1
# SIM_HEADLESS=true

# Vercel: add the same keys in Project → Settings → Environment Variables
# (Production + Preview). AUTH_SECRET, NEXT_PUBLIC_SUPABASE_URL, and
# SUPABASE_SERVICE_ROLE_KEY are required for login/sign-up. Run supabase/schema.sql
# in the Supabase SQL editor. NEXT_PUBLIC_APP_URL is optional for server-side
# API calls (the app uses the request host on Vercel); set it if you need an
# absolute URL for emails or links.
